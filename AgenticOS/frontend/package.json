{
  "name": "agenticos-command-center-frontend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "AgenticOS Command Center React frontend (Plan 3 scaffold). Submarine + Harry Potter themed instrument panel for parallel Claude Code sub-agents.",
  "author": "Marcus Daley",
  "license": "UNLICENSED",
  "scripts": {
    "dev": "vite",
    "build": "npx tsc --noEmit && npx vite build",
