<!--
  agentic_dashboard.xaml
  Developer: Marcus Daley
  Date: 2026-04-29
  Purpose: WPF chrome for the AgenticOS Command Center. Borderless
           window with a custom title bar (drag region plus minimize,
           maximize, close glyphs), a one-pixel gold border surrounding
           a deep-navy fill, and a single content Grid named
           WebView2Host that the Python launcher fills with a WebView2
           instance at runtime. Every brush is defined once in the
           ResourceDictionary at the top of the file so the palette
           lives in exactly one place.
-->
<Window
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="AgenticOS Command Center"
    Width="1280"
    Height="800"
    MinWidth="800"
    MinHeight="600"
    WindowStyle="None"
    AllowsTransparency="False"
    ResizeMode="CanResizeWithGrip"
    WindowStartupLocation="Manual"
    UseLayoutRounding="True"
    SnapsToDevicePixels="True"
    Background="#1B2838"
    Foreground="#F5E6C8"
    FontFamily="Segoe UI"
    FontSize="13">

    <Window.Resources>
        <ResourceDictionary>

            <!--
              ============================================================
              Palette
              Submarine + Harry Potter theme. Hex values match the OWL
              Watcher window so the two apps look like siblings sitting
              next to each other on the desktop.
              ============================================================
            -->
            <SolidColorBrush x:Key="DeepNavyBrush"     Color="#1B2838" />
            <SolidColorBrush x:Key="NavyLightBrush"    Color="#263A4F" />
            <SolidColorBrush x:Key="DarkTealBrush"     Color="#1A3C40" />
            <SolidColorBrush x:Key="StatusBarBrush"    Color="#0F1A24" />
            <SolidColorBrush x:Key="GoldAccentBrush"   Color="#C9A94E" />
            <SolidColorBrush x:Key="BorderGoldBrush"   Color="#8B7435" />
            <SolidColorBrush x:Key="ParchmentBrush"    Color="#F5E6C8" />
            <SolidColorBrush x:Key="DimTextBrush"      Color="#8899AA" />
            <SolidColorBrush x:Key="CloseHoverBrush"   Color="#8B1A1A" />

            <!--
              ============================================================
              Title-bar chrome button (minimize / maximize)
              Square 40x32 hit target, transparent base, navy-light hover,
              dark-teal pressed. Foreground swaps from dim to parchment
              on hover so the glyph stays readable in both states.
              ============================================================
            -->
            <Style x:Key="ChromeButtonStyle" TargetType="Button">
                <Setter Property="Background"      Value="Transparent" />
                <Setter Property="Foreground"      Value="{StaticResource DimTextBrush}" />
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="Width"           Value="40" />
                <Setter Property="Height"          Value="32" />
                <Setter Property="FontFamily"      Value="Segoe UI" />
                <Setter Property="FontSize"        Value="13" />
                <Setter Property="Cursor"          Value="Hand" />
                <Setter Property="FocusVisualStyle" Value="{x:Null}" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="ChromeBtnSurface"
                                    Background="{TemplateBinding Background}"
                                    BorderThickness="0">
                                <ContentPresenter
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    TextElement.Foreground="{TemplateBinding Foreground}" />
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="ChromeBtnSurface"
                                            Property="Background"
                                            Value="{StaticResource NavyLightBrush}" />
                                    <Setter Property="Foreground"
                                            Value="{StaticResource ParchmentBrush}" />
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="ChromeBtnSurface"
                                            Property="Background"
                                            Value="{StaticResource DarkTealBrush}" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!--
              Close button extends the chrome style with a red hover so
              users get the standard Windows visual cue that this is the
              destructive action. The base style keeps every other
              property in sync with minimize and maximize.
            -->
            <Style x:Key="CloseButtonStyle"
                   TargetType="Button"
                   BasedOn="{StaticResource ChromeButtonStyle}">
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background"
                                Value="{StaticResource CloseHoverBrush}" />
                        <Setter Property="Foreground"
                                Value="{StaticResource ParchmentBrush}" />
                    </Trigger>
                </Style.Triggers>
            </Style>

        </ResourceDictionary>
    </Window.Resources>

    <!--
      ============================================================
      Outer gold hairline. The single-pixel border is what gives the
      window the "submarine porthole" feel against the desktop.
      Inside the border, a DockPanel partitions the window into a
      32-pixel title bar at the top and the WebView2 host filling
      the rest. LastChildFill ensures the host expands as the user
      resizes the window.
      ============================================================
    -->
    <Border BorderBrush="{StaticResource BorderGoldBrush}" BorderThickness="1">
        <DockPanel LastChildFill="True">

            <!--
              Title bar. Background is the darkest tone in the palette
              so the gold accents on top read with maximum contrast.
              The bottom border is a single pixel of gold to visually
              separate it from the WebView2 host below.
            -->
            <Border x:Name="TitleBar"
                    DockPanel.Dock="Top"
                    Height="32"
                    Background="{StaticResource StatusBarBrush}"
                    BorderBrush="{StaticResource BorderGoldBrush}"
                    BorderThickness="0,0,0,1">
                <DockPanel LastChildFill="True">

                    <!--
                      Window-control cluster docked right. Order matches
                      every modern Windows app so the muscle memory of a
                      typical user is preserved.
                    -->
                    <StackPanel DockPanel.Dock="Right"
                                Orientation="Horizontal">
                        <Button x:Name="MinimizeButton"
                                Style="{StaticResource ChromeButtonStyle}"
                                Content="&#x2212;"
                                ToolTip="Minimize" />
                        <Button x:Name="MaximizeButton"
                                Style="{StaticResource ChromeButtonStyle}"
                                Content="&#x25A1;"
                                ToolTip="Maximize / Restore" />
                        <Button x:Name="CloseButton"
                                Style="{StaticResource CloseButtonStyle}"
                                Content="&#x2715;"
                                ToolTip="Hide to system tray" />
                    </StackPanel>

                    <!--
                      Server status indicator dot. Default colour is the
                      dim grey "unknown" state; the launcher mutates the
                      Fill brush to gold when the supervisor reports
                      "running" and to CloseHoverBrush for "failed".
                    -->
                    <Ellipse x:Name="ServerStatusDot"
                             DockPanel.Dock="Right"
                             Width="8"
                             Height="8"
                             Margin="0,0,12,0"
                             VerticalAlignment="Center"
                             Fill="{StaticResource DimTextBrush}"
                             ToolTip="Server status: unknown" />

                    <!--
                      Brand wordmark on the left. Gold colour pulled from
                      the palette so a single edit there re-themes the
                      entire window.
                    -->
                    <TextBlock x:Name="TitleLabel"
                               Margin="14,0,0,0"
                               VerticalAlignment="Center"
                               Foreground="{StaticResource GoldAccentBrush}"
                               FontWeight="SemiBold"
                               FontSize="13"
                               Text="AgenticOS Command Center" />
                </DockPanel>
            </Border>

            <!--
              ============================================================
              WebView2 host. The Python launcher inserts the actual
              WebView2 instance here at runtime because XamlReader.Parse
              cannot resolve the Microsoft.Web.WebView2.Wpf namespace
              (it is registered through pythonnet, not at parse time).
              The LoadingLabel is the placeholder shown while the
              control is being created and while the supervised server
              is still in its readiness probe.
              ============================================================
            -->
            <Grid x:Name="WebView2Host"
                  Background="{StaticResource DeepNavyBrush}">
                <TextBlock x:Name="LoadingLabel"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           FontSize="16"
                           Foreground="{StaticResource DimTextBrush}"
                           Text="Connecting to AgenticOS..." />
            </Grid>

        </DockPanel>
    </Border>
</Window>
